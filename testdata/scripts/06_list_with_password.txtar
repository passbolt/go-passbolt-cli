# list --column Password triggers secret decryption — the Password field for
# the v5 resource must be present and decrypted in the JSON output.

pb create resource --type v5-default --name test-list-pass --password pass-v5-decrypted --json
cp stdout create.json
jsonget create.json id ID
defer pb delete resource --id $ID

pb list resource --column ID --column Name --column Password --json
cp stdout list.json
jsoneq list.json [id=$ID].password pass-v5-decrypted

