# Set and clear an absolute --expiry on a v5 resource.

pb create resource --type v5-default --name test-expiry --password expiry-pass --json
cp stdout create.json
jsonget create.json id ID
defer pb delete resource --id $ID

pb update resource --id $ID --expiry 2030-01-01T00:00:00Z

pb update resource --id $ID --expiry none

pb get resource --id $ID --json
cp stdout get.json
jsoneq get.json name test-expiry

