# CEL filters that reach into the Metadata and Secret maps. For v5 resources,
# normalised paths (Metadata.uri from the "uris" array, Metadata.description
# stored in metadata) must be queryable.

pb create resource --type v5-default --name test-meta-filter --username meta-user --uri https://meta-filter.example.com --password meta-pass --description 'meta description' --json
cp stdout create.json
jsonget create.json id ID
defer pb delete resource --id $ID

# Metadata.name (top-level metadata field).
pb list resource --filter 'Metadata.name == "test-meta-filter"' --json
stdout $ID

# Metadata.uri normalised from the v5 "uris" array.
pb list resource --filter 'Metadata.uri == "https://meta-filter.example.com"' --json
stdout $ID

# Secret.password — requires secret decryption.
pb list resource --filter 'has(Secret.password) && Secret.password == "meta-pass"' --json
stdout $ID

# Metadata.description (description stored on the metadata side for v5-default).
pb list resource --filter 'Metadata.description == "meta description"' --json
stdout $ID

# Combined: top-level Name contains + nested Metadata.uri.
pb list resource --filter 'Name.contains("test-meta") && Metadata.uri == "https://meta-filter.example.com"' --json
stdout $ID

